# Allow all static assets and engines required by the application
!src/rocktranslate/assets/**/*.html
!src/rocktranslate/assets/**/*.json
!src/rocktranslate/assets/**/*.js
!src/rocktranslate/assets/**/*.css
!src/rocktranslate/assets/**/*.ico
!src/rocktranslate/assets/**/*.png
!src/rocktranslate/assets/**/*.exe
!src/rocktranslate/assets/**/*.ttf

# Prevent bytecode compilation caches anywhere in the project
**/__pycache__/
**/*.pyc

# Prevent local application logs in the new package structure
src/rocktranslate/logs/
**/logs/
*.log

# Prevent temporary runtime HTML/CSS files generated by pdf2htmlEX during extraction
src/rocktranslate/assets/fonts/tmp*
**/tmp*